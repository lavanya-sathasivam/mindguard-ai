# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
ENV/
env/

# Environment files (do NOT commit secrets)
.env
.env.*

# Python cache, testing, tooling
.pytest_cache/
pip-wheel-metadata/
__pypackages__/
.mypy_cache/
.cache/

# Logs and databases
*.log
*.sqlite3

# Editor directories and files
.vscode/
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
/.next/
out/
.vercel/

# Coverage
.coverage
.coverage.*
htmlcov/

# Optional: lockfiles (commonly committed, uncomment if you want to ignore)
# package-lock.json
# yarn.lock
